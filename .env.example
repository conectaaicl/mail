# Authentication
AUTH_SECRET=genera-una-clave-segura-con-openssl-rand-hex-32

# Database (auto-set by docker-compose, no cambiar)
DATABASE_URL=file:/app/prisma/data/prod.db

# SMTP — opción A: Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-app-password-de-google
SMTP_FROM=tu-email@gmail.com

# SMTP — opción B: Resend (recomendado, no requiere abrir puertos)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
# SMTP_FROM=noreply@tudominio.com

# API Key para /api/send (genera con: openssl rand -hex 32)
INTERNAL_API_KEY=

# n8n integration
N8N_WEBHOOK_URL=https://n8n.conectaai.cl/webhook/correo-entrante
